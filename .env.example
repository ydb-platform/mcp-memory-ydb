# Copy to .mcp-memory-ydb.env and fill in the values.
# Run `mcp-memory-ydb setup` for interactive configuration.

# LLM — any provider with an OpenAI-compatible API
LLM_BASE_URL=                        # Yandex Cloud: https://llm.api.cloud.yandex.net/v1 | OpenAI: https://api.openai.com/v1 | Ollama: http://localhost:11434/v1
LLM_MODEL=                           # gpt-4o-mini | llama3 | gpt://folder_id/yandexgpt-5.1/latest | ...
LLM_API_KEY=                         # API key

# Embeddings
EMBEDDINGS_BASE_URL=                 # if different from LLM_BASE_URL
EMBEDDINGS_MODEL=                    # Yandex: emb://folder_id/text-search-query/latest | OpenAI: text-embedding-3-small | Ollama: nomic-embed-text
EMBEDDINGS_API_KEY=                  # if different from LLM_API_KEY

# YDB Serverless
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=                        # /ru-central1/<folder>/<db>
YDB_SA_KEY_FILE=                     # path to the service-account JSON key (role ydb.editor)
YDB_SA_KEY=                          # alternative to YDB_SA_KEY_FILE: the same key inline, as a JSON string

# Search and timeouts
MEMORY_NAMESPACE=                    # partitions memory, e.g. per project/agent (default: "default"). A filter label, not a security boundary.
MEMORY_FACT_INSTRUCTIONS=            # empty = mem0 default (facts in English). To keep the user's language, write the instruction IN that language, e.g. (RU): Сохраняй каждый факт на языке исходного сообщения, не переводи.
MEMORY_THRESHOLD=0.15                # minimum cosine score (0–1); lower = more results
MEMORY_TIMEOUT=30                    # memory operation timeout, seconds
PROBE_TIMEOUT=                       # startup LLM/embeddings probe timeout (default = MEMORY_TIMEOUT)
YDB_TIMEOUT=                         # YDB discovery_request_timeout (default = MEMORY_TIMEOUT)
